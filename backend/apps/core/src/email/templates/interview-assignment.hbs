<html>
    <head>
        <meta charset='utf-8' />
        <meta name='viewport' content='width=device-width,initial-scale=1' />
        <style
        >
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background: {{primaryColor}};
            color: #fff;
            padding: 30px;
            text-align: center;
            border-radius: 8px 8px 0 0;
        }
        .logo {
            max-width: 150px;
            margin-bottom: 20px;
        }
        .content {
            background: #f9f9f9;
            padding: 30px;
            border-radius: 0 0 8px 8px;
        }
        .portal-box {
            background: #f0f8ff;
            padding: 15px;
            border-radius: 6px;
            margin: 15px 0;
            text-align: center;
        }
        .portal-box a {
            color: {{primaryColor}};
            font-weight: bold;
            font-size: 16px;
            text-decoration: none;
            word-break: break-all;
        }
        .ps-note {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 15px;
            margin-top: 20px;
            font-size: 14px;
            color: #856404;
        }
        .footer {
            text-align: center;
            margin-top: 30px;
            color: #666;
            font-size: 12px;
        }
        a {
            color: {{primaryColor}};
        }
    </style>
    </head>
    <body>
        <div class='container'>
            <div class='header'>
                {{#if logoUrl}}
                    <img src='{{logoUrl}}' alt='{{companyName}}' class='logo' />
                {{/if}}
                <h1>📌 Your Interview is Scheduled</h1>
            </div>

            <div class='content'>
                <p>Dear {{applicantName}},</p>

                <p>
                    Your interview for the
                    <strong>{{jobTitle}}</strong>
                    position at
                    <strong>{{companyName}}</strong>
                    has been scheduled.
                </p>

                <p>
                    Please log in to the applicant portal to select your
                    preferred time slot and confirm your attendance.
                </p>

                <div class='portal-box'>
                    <p><strong>Applicant Portal</strong></p>
                    <p>
                        <a
                            href='{{portalLink}}'
                            target='_blank'
                            rel='noopener noreferrer'
                        >
                            {{portalLink}}
                        </a>
                    </p>
                    <p style='font-size:12px;color:#666;margin-top:10px'>
                        Use your **email password** to log in. If you have
                        updated your password, use the latest one. Selecting a
                        time slot will confirm your interview.
                    </p>
                </div>

                <div class='ps-note'>
                    <strong>P.S.</strong>
                    This is an automated message. Please do not reply to this
                    email. For any questions, contact us at
                    <a href='mailto:{{companyEmail}}'>{{companyEmail}}</a>.
                </div>
            </div>

            <div class='footer'>
                <p>&copy; {{year}} {{companyName}}. All rights reserved.</p>
            </div>
        </div>
    </body>
</html>