<html>
    <head>
        <meta charset='utf-8' />
        <meta name='viewport' content='width=device-width,initial-scale=1' />
        <style>
            body {
                font-family: Arial, sans-serif;
                line-height: 1.6;
                color: #333;
                margin: 0;
                padding: 0;
            }
            .container {
                max-width: 600px;
                margin: 0 auto;
                padding: 20px;
            }
            .header {
                background: #2563eb;
                color: #fff;
                padding: 30px;
                text-align: center;
                border-radius: 8px 8px 0 0;
            }
            .content {
                background: #f9f9f9;
                padding: 30px;
                border-radius: 0 0 8px 8px;
            }
            .info-box {
                background: #ffffff;
                border: 1px solid #e5e7eb;
                padding: 16px;
                border-radius: 8px;
                margin: 20px 0;
            }
            .label {
                font-size: 13px;
                color: #666;
                margin: 0 0 6px 0;
            }
            .value {
                font-size: 16px;
                font-weight: bold;
                margin: 0;
                word-break: break-word;
            }
            .password-box {
                background: #ffffff;
                border: 1px solid #e5e7eb;
                padding: 16px;
                border-radius: 8px;
                margin: 20px 0;
                text-align: center;
                font-size: 18px;
                font-weight: bold;
                letter-spacing: 2px;
            }
            .note {
                background: #fff3cd;
                border-left: 4px solid #ffc107;
                padding: 15px;
                margin-top: 20px;
                font-size: 14px;
                color: #856404;
            }
            .footer {
                text-align: center;
                margin-top: 30px;
                color: #666;
                font-size: 12px;
            }
            a {
                color: #2563eb;
            }
        </style>
    </head>

    <body>
        <div class='container'>
            <div class='header'>
                <h1>🔐 Your Jobsinc Account Details</h1>
            </div>

            <div class='content'>
                <p>Dear {{applicantName}},</p>

                <p>
                    Your Jobsinc account has been created successfully. Please
                    use the details below to log in:
                </p>

                <div class='portal-box'>
                    <p><strong>Applicant Portal</strong></p>
                    <p>
                        <a
                            href='{{portalLink}}'
                            target='_blank'
                            rel='noopener noreferrer'
                        >
                            {{portalLink}}
                        </a>
                    </p>
                </div>

                <div class='info-box'>
                    <p class='label'>Email</p>
                    <p class='value'>{{applicantEmail}}</p>
                </div>

                <div class='password-box'>{{password}}</div>

                <p>
                    For security reasons, we strongly recommend that you change
                    your password after your first login.
                </p>

                <div class='note'>
                    <strong>Note:</strong>
                    This is an automated message. Please do not reply to this
                    email.
                </div>
            </div>

            <div class='footer'>
                <p>&copy; {{year}} Jobsinc. All rights reserved.</p>
            </div>
        </div>
    </body>
</html>